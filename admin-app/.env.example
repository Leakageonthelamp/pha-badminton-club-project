PUBLIC_APP_NAME=Antonsmash Admin
PUBLIC_APP_SHORT_NAME=Antonsmash Admin
PUBLIC_APP_VERSION=0.1.0
PORT=5174

PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# Admin sessions last 30 days (cookie maxAge in app). Supabase Auth > Sessions time-box
# must be at least 720 hours (30 days) or refresh will fail before the cookie expires.
# SHA-256 hex of the raw master key (never store the raw key here)
# Generate: node -e "console.log(require('crypto').createHash('sha256').update('your-secret').digest('hex'))"
MASTER_KEY_SHA256=

# Upper limit for club max_active_sessions (default 50)
CLUB_MAX_ACTIVE_SESSIONS_LIMIT=50

# Upper limit for club max_admins setting (default 20)
CLUB_MAX_ADMINS_LIMIT=20
